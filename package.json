{
  "name": "signalk-wave-estimator",
  "version": "0.1.0-alpha",
  "description": "Estimate sea state from boat motion: derive true wave period, length, celerity and a slope-inversion height proxy from pitch/roll, corrected for speed through water. Publishes environment.wave.*. Alpha — height is a proxy, no heave sensor.",
  "main": "index.js",
  "scripts": {
    "test": "node test/sanity.js"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "wave",
    "sea-state",
    "seakeeping",
    "attitude",
    "wave-buoy-analogy"
  ],
  "files": [
    "index.js",
    "lib/",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "signalk": {
    "displayName": "Wave estimator"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johansolve/signalk-wave-estimator.git"
  },
  "bugs": {
    "url": "https://github.com/johansolve/signalk-wave-estimator/issues"
  },
  "homepage": "https://github.com/johansolve/signalk-wave-estimator#readme",
